{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "EmulateurClavier",
            "type": "gdb",
            "request": "attach",
            "gdbpath": "${env:HOME}/arm-cross-comp-env/arm-raspbian-linux-gnueabi/bin/arm-raspbian-linux-gnueabi-gdb",
            "executable": "./build/emulateurClavier",
            "target": "10.242.100.158:4560",
            "remote": true,
            "autorun": [
                "set sysroot ${env:HOME}/arm-cross-comp-env/arm-raspbian-linux-gnueabi/arm-raspbian-linux-gnueabi/sysroot/"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "syncAndStartGDB"
        },
        {
            "name": "Debug local (simulation)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-native/emulateurClavier",
            "args": [
                "/tmp/test_pipe",
                "1000",
                "10"
            ],
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "build-native",
            // "externalConsole": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}