{
    "cmake.configureOnOpen": true,
    "files.associations": {
        "allocateurmemoire.h": "c",
        "pthread.h": "c",
        "tamponcirculaire.h": "c",
        "emulateurclavier.h": "c",
        "time.h": "c",
        "stdlib.h": "c",
        "fcntl.h": "c",
        "unistd.h": "c",
        "utils.h": "c"
    },
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.formatting": "disabled",
    "clangd.path": "clangd",
    "clangd.arguments": [
        "--background-index",
        "--clang-tidy"
    ],
    "editor.formatOnSave": true,
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll": "always",
        "source.fixAll.clangd": "always"
    }
}