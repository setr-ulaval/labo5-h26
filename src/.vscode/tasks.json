{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "syncAndStartGDB",
            "type": "shell",
            "command": "./syncAndStartGDB.sh ${workspaceFolder} emulateurClavier 4560",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "toutSynchroniser",
            "type": "shell",
            "command": "./syncAndStartGDB.sh ${workspaceFolder} all",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "build-native",
            "type": "shell",
            "command": "make -f Makefile.native all",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "test-native",
            "type": "shell",
            "command": "make -f Makefile.native test",
            "group": "test",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
